programa {
  funcao inicio() {
      real numero1
      real numero2
        escreva("Escreva o primeio número:\n")
        leia(numero1)
        escreva("Escreva o segundo número:\n")
        leia(numero2)
        se (numero1>numero2) {
          escreva(numero1)
        } senao {escreva(numero2)}
  }
}
